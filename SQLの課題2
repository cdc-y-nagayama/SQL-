SELECT
    m_job1.id,
    m_job1.name,
    COUNT(entry.type_user_id_fk)               entry_count,
    COUNT(DISTINCT entry.type_user_id_fk) entry_user_count,
    MAX(
        TIMESTAMPDIFF(
            YEAR,
            entry_resume.birthday,
            CURDATE()
        )
    ) max_age
FROM entry
INNER JOIN entry_offer_snapshot on entry.entry_id = entry_offer_snapshot.entry_id_fk
INNER JOIN entry_resume on entry_offer_snapshot.entry_id_fk = entry_resume.entry_id_fk
INNER JOIN m_job1 on m_job1.id = entry_resume.entry_id_fk

WHERE
    entry.entry_at >= '2026-01-01'
    AND entry.entry_at <  '2026-04-01'
GROUP BY
    m_job1.id,
    m_job1.name
ORDER BY
    entry_count DESC
;

