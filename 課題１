select 
        entry.entry_id,
	    entry.entry_at,
        entry.type_user_id_fk,
        entry_offer_snapshot.offer_name,
        entry_resume.is_working
       --  entry.is_request_casual_interview


from entry
INNER JOIN entry_offer_snapshot on entry.entry_id = entry_offer_snapshot.entry_id_fk
INNER JOIN entry_resume on entry_offer_snapshot.entry_id_fk = entry_resume.entry_id_fk
WHERE entry.entry_at != '2026-04-10'
and   entry.is_request_casual_interview  = 0
